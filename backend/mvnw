# ----------------------------------------------------------------------------
# Maven Start Up Batch script
# ----------------------------------------------------------------------------

MAVEN_PROJECTBASEDIR=`pwd`
MAVEN_ARGUMENTS=$*

if [ -z "$JAVA_HOME" ] ; then
  JAVA_EXE=java
else
  JAVA_EXE=$JAVA_HOME/bin/java
fi

WRAPPER_JAR=$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar
WRAPPER_MAIN=org.apache.maven.wrapper.MavenWrapperMain

"$JAVA_EXE" $MAVEN_OPTS "-Dmaven.multiModuleProjectDirectory=$MAVEN_PROJECTBASEDIR" -classpath "$WRAPPER_JAR" $WRAPPER_MAIN $MAVEN_ARGUMENTS
exit $?
